<!-- Breadcrumb -->
<div class="bg-gray-100 border-b border-gray-200">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-4">
        <a href="/donations" class="text-primary-600 hover:text-primary-700 font-medium flex items-center gap-2 transition">
            <i class="fas fa-arrow-<%= isRTL ? 'right' : 'left' %>"></i>
            <%= t('donationDetails.back') %>
        </a>
    </div>
</div>

<!-- Donation Details -->
<section class="py-8 bg-gray-50">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="grid md:grid-cols-2 gap-8">

            <!-- Image Section -->
            <div class="bg-white rounded-2xl overflow-hidden shadow-lg">
                <div class="relative h-[400px] md:h-[500px]">
                    <img 
                        src="<%= donation.imageUrl %>" 
                        alt="<%= donation.itemName %>" 
                        class="w-full h-full object-cover"
                    >

                    <!-- Category Badge -->
                    <div class="absolute top-4 <%= isRTL ? 'right-4' : 'left-4' %>">
                        <span class="bg-white/90 backdrop-blur-sm text-sm font-bold px-4 py-2 rounded-full uppercase tracking-wide shadow-md">
                            <%= t('donations.' + donation.category) %>
                        </span>
                    </div>

                    <!-- Status Badge -->
                    <div class="absolute top-4 <%= isRTL ? 'left-4' : 'right-4' %>">
                        <% if (donation.status === 'available') { %>
                            <span class="bg-green-500 text-white text-sm font-bold px-4 py-2 rounded-full shadow-md">
                                <%= t('donationDetails.available') %>
                            </span>
                        <% } else if (donation.status === 'reserved') { %>
                            <span class="bg-orange-500 text-white text-sm font-bold px-4 py-2 rounded-full shadow-md">
                                <%= t('donationDetails.reserved') %>
                            </span>
                        <% } else { %>
                            <span class="bg-gray-500 text-white text-sm font-bold px-4 py-2 rounded-full shadow-md">
                                <%= t('donationDetails.donated') %>
                            </span>
                        <% } %>
                    </div>
                </div>
            </div>

            <!-- Details Section -->
            <div class="space-y-6">
                <div class="bg-white rounded-2xl shadow-lg p-6 md:p-8">

                    <!-- Title -->
                    <h1 class="text-2xl md:text-3xl font-bold text-gray-800 mb-2"><%= donation.itemName %></h1>

                    <!-- Meta Info -->
                    <div class="flex flex-wrap gap-4 text-sm text-gray-500 mb-6">
                        <span class="flex items-center gap-1">
                            <i class="fas fa-calendar-alt"></i>
                            <%= t('donationDetails.addedOn') %>: <%= donation.formattedDate %>
                        </span>
                        <span class="flex items-center gap-1">
                            <i class="fas fa-eye"></i>
                            <%= donation.views %> <%= t('donationDetails.views') %>
                        </span>
                    </div>

                    <!-- Details Grid -->
                    <div class="grid grid-cols-2 gap-4 mb-6">
                        <div class="bg-gray-50 rounded-xl p-4">
                            <p class="text-xs text-gray-500 uppercase tracking-wide mb-1"><%= t('donationDetails.category') %></p>
                            <p class="font-semibold text-gray-800"><%= t('donations.' + donation.category) %></p>
                        </div>

                        <div class="bg-gray-50 rounded-xl p-4">
                            <p class="text-xs text-gray-500 uppercase tracking-wide mb-1"><%= t('donationDetails.size') %></p>
                            <p class="font-semibold text-gray-800"><%= donation.size %></p>
                        </div>

                        <div class="bg-gray-50 rounded-xl p-4">
                            <p class="text-xs text-gray-500 uppercase tracking-wide mb-1"><%= t('donationDetails.condition') %></p>
                            <p class="font-semibold text-gray-800"><%= t('donations.' + donation.condition) %></p>
                        </div>

                        <div class="bg-gray-50 rounded-xl p-4">
                            <p class="text-xs text-gray-500 uppercase tracking-wide mb-1"><%= t('donationDetails.city') %></p>
                            <p class="font-semibold text-gray-800"><%= donation.city %></p>
                        </div>
                    </div>

                    <!-- Description -->
                    <% if (donation.description) { %>
                        <div class="mb-6">
                            <h3 class="text-sm font-semibold text-gray-700 mb-2"><%= t('addDonation.description') %></h3>
                            <p class="text-gray-600 leading-relaxed bg-gray-50 rounded-xl p-4"><%= donation.description %></p>
                        </div>
                    <% } %>

                    <!-- Donor Info -->
                    <% if (donation.donorName) { %>
                        <div class="mb-6 flex items-center gap-3 bg-primary-50 rounded-xl p-4">
                            <div class="w-10 h-10 bg-primary-500 rounded-full flex items-center justify-center">
                                <i class="fas fa-user text-white"></i>
                            </div>
                            <div>
                                <p class="text-xs text-gray-500"><%= isRTL ? 'متبرع' : 'Donor' %></p>
                                <p class="font-semibold text-gray-800"><%= donation.donorName %></p>
                            </div>
                        </div>
                    <% } %>

                    <!-- Contact Section -->
                    <% if (donation.status === 'available') { %>
                        <div class="bg-gradient-to-r from-green-50 to-emerald-50 rounded-xl p-6 border border-green-200">
                            <h3 class="font-bold text-lg text-gray-800 mb-2">
                                <i class="fas fa-handshake text-green-600 mr-2 rtl:ml-2 rtl:mr-0"></i>
                                <%= t('donationDetails.contactTitle') %>
                            </h3>
                            <p class="text-gray-600 text-sm mb-4"><%= t('donationDetails.contactText') %></p>

                            <a 
                                href="<%= whatsappLink %>" 
                                target="_blank"
                                class="w-full bg-green-500 hover:bg-green-600 text-white font-bold py-3.5 px-6 rounded-xl transition shadow-lg hover:shadow-xl transform hover:-translate-y-0.5 flex items-center justify-center gap-3 whatsapp-pulse"
                            >
                                <i class="fab fa-whatsapp text-2xl"></i>
                                <span><%= t('donationDetails.contactBtn') %></span>
                            </a>
                        </div>
                    <% } else { %>
                        <div class="bg-gray-100 rounded-xl p-6 text-center">
                            <i class="fas fa-info-circle text-gray-400 text-3xl mb-2"></i>
                            <p class="text-gray-500 font-medium">
                                <% if (donation.status === 'reserved') { %>
                                    <%= isRTL ? 'هذه القطعة محجوزة حالياً.' : 'This item is currently reserved.' %>
                                <% } else { %>
                                    <%= isRTL ? 'تم التبرع بهذه القطعة.' : 'This item has been donated.' %>
                                <% } %>
                            </p>
                        </div>
                    <% } %>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Related Donations -->
<% if (relatedDonations && relatedDonations.length > 0) { %>
    <section class="py-12 bg-white">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            <h2 class="text-2xl font-bold text-gray-800 mb-8"><%= t('donationDetails.relatedTitle') %></h2>

            <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
                <% relatedDonations.forEach(item => { %>
                    <div class="donation-card bg-white rounded-2xl overflow-hidden shadow-md border border-gray-100">
                        <div class="image-zoom h-40">
                            <img src="<%= item.imageUrl %>" alt="<%= item.itemName %>" class="w-full h-full object-cover">
                        </div>
                        <div class="p-4">
                            <h3 class="font-bold text-gray-800 mb-1 truncate"><%= item.itemName %></h3>
                            <div class="flex items-center justify-between">
                                <span class="text-xs text-gray-500"><%= item.city %></span>
                                <span class="text-xs bg-primary-100 text-primary-700 px-2 py-0.5 rounded-full"><%= item.size %></span>
                            </div>
                            <a href="/donations/<%= item._id %>" class="mt-3 block text-center text-primary-600 hover:text-primary-700 font-medium text-sm py-2 border border-primary-200 rounded-lg hover:bg-primary-50 transition">
                                <%= t('donations.detailsBtn') %>
                            </a>
                        </div>
                    </div>
                <% }) %>
            </div>
        </div>
    </section>
<% } %>
